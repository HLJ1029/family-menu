ARK_API_KEY=your_volcengine_ark_api_key
SEEDREAM_MODEL=doubao-seedream-4-0-250828
# Humi API
HUMI_API_PORT=8787
HUMI_API_DATA_FILE=.humi-api-data.json
HUMI_SESSION_SECRET=replace_with_a_long_random_secret
HUMI_ALLOWED_ORIGINS=https://www.humi-home.com,http://localhost:5173,http://127.0.0.1:5173
WECHAT_APP_ID=your_wechat_miniprogram_appid
WECHAT_APP_SECRET=your_wechat_miniprogram_appsecret
HUMI_WECHAT_MOCK=0
HUMI_COLLABORATION_RATE_LIMIT=120
HUMI_COLLABORATION_RATE_WINDOW_MS=60000
HUMI_REQUEST_BODY_LIMIT_BYTES=65536
# HMAC-SHA256 salt for anonymous telemetry session hashes. Required in production.
HUMI_TELEMETRY_HASH_SALT=replace_with_a_separate_long_random_salt
HUMI_TELEMETRY_RATE_LIMIT=120
HUMI_TELEMETRY_RATE_WINDOW_MS=60000

# “每周做成两顿”灰度；默认关闭，仅同时命中总开关和家庭白名单才生效。
HUMI_MEAL_EXECUTION_ENABLED=0
HUMI_MEAL_EXECUTION_HOUSEHOLDS=
# Native mini-program shell; both the global switch and household allowlist must match.
HUMI_NATIVE_SHELL_ENABLED=0
HUMI_NATIVE_SHELL_HOUSEHOLDS=
# 微信一次性订阅消息模板及字段 key；模板 ID 不是密钥，但由服务端统一下发。
HUMI_MEAL_REMINDER_TEMPLATE_ID=
HUMI_MEAL_REMINDER_THING_KEY=thing1
HUMI_MEAL_REMINDER_TIME_KEY=time2

# DeepSeek 自建 AI 推荐（仅由自建 API 使用）
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_BASE_URL=https://api.deepseek.com

# H5 调用 Humi API；留空时使用正式 API 域名。
VITE_HUMI_API_BASE_URL=
