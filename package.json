{
  "name": "family-menu",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host 0.0.0.0",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "generate:dish-images": "node scripts/generate-dish-images.mjs",
    "generate:dish-thumbs": "node scripts/generate-dish-thumbnails.mjs",
    "generate:dish-webp": "node scripts/generate-dish-webp.mjs",
    "validate:characters": "node scripts/validate-character-illustrations.mjs",
    "validate:data": "node scripts/validate-recipes.mjs",
    "validate:images": "node scripts/validate-dish-assets.mjs",
    "api:dev": "node --env-file-if-exists=.env.local api/server.js",
    "validate:api": "HUMI_WECHAT_MOCK=1 HUMI_API_DATA_FILE=/tmp/humi-api-smoke.json node scripts/smoke-humi-api.mjs",
    "validate:recommendation": "node scripts/check-recommendation-constraints.mjs",
    "deploy:api:check": "node scripts/check-api-deploy-readiness.mjs",
    "monitor:prod": "node scripts/check-production-health.mjs",
    "release:check": "node scripts/check-launch-readiness.mjs",
    "release:check:online": "node scripts/check-launch-readiness.mjs --online",
    "release:evidence:check": "node scripts/check-release-evidence-log.mjs",
    "release:evidence:record:submit": "node scripts/record-wechat-submit-evidence.mjs",
    "release:next": "node scripts/print-release-next-action.mjs",
    "release:status": "node scripts/check-release-status.mjs",
    "release:wechat:copy": "node scripts/print-wechat-submit-copy.mjs",
    "release:wechat:check": "node scripts/check-wechat-submit-readiness.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.2",
    "@vitejs/plugin-react": "^5.1.1",
    "autoprefixer": "^10.4.22",
    "lucide-react": "^0.556.0",
    "postcss": "^8.5.6",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "tailwindcss": "^3.4.18",
    "vite": "^7.2.4"
  },
  "devDependencies": {
    "playwright": "^1.60.0"
  }
}
