page { min-height: 100vh; background: #f5f5f3; color: #111; }
.task-page { padding: 52rpx 30rpx 100rpx; }
.eyebrow { display: block; color: rgba(17,17,17,.42); font-size: 21rpx; font-weight: 900; letter-spacing: .1em; }
.title { display: block; margin-top: 14rpx; font-size: 48rpx; line-height: 1.22; font-weight: 900; }
.copy,.quiet { display: block; margin-top: 18rpx; color: rgba(17,17,17,.58); font-size: 25rpx; line-height: 1.6; font-weight: 700; }
.status-card { margin-top: 36rpx; padding: 30rpx; border-radius: 30rpx; background: #fff; box-shadow: 0 20rpx 64rpx rgba(17,17,17,.05); }
.status-label { display: block; font-size: 31rpx; font-weight: 900; }
.meta { display: block; margin-top: 8rpx; color: rgba(17,17,17,.46); font-size: 22rpx; font-weight: 800; }
.primary-button,.secondary-button { min-height: 94rpx; margin-top: 28rpx; border-radius: 999rpx; font-size: 26rpx; font-weight: 900; }
.primary-button { background: #111; color: #fff; }
.secondary-button { border: 2rpx solid rgba(17,17,17,.12); background: #fff; color: #111; }
.secondary-button[disabled] { color: #999; }
.share-retry { display: block; margin-top: 16rpx; color: #7b2929; font-size: 24rpx; text-align: center; text-decoration: underline; }
.inline-error { display: block; margin-top: 18rpx; color: #7b2929; font-size: 23rpx; line-height: 1.5; font-weight: 800; }
