page { min-height: 100vh; background: #f5f5f3; color: #111; }
.settings-page { padding: 30rpx 28rpx 100rpx; }
.hero-card,.section-card { margin-bottom: 24rpx; padding: 34rpx; border: 2rpx solid rgba(17,17,17,.08); border-radius: 34rpx; background: #fff; box-shadow: 0 20rpx 64rpx rgba(17,17,17,.05); }
.eyebrow { display: block; color: rgba(17,17,17,.42); font-size: 21rpx; font-weight: 900; letter-spacing: .09em; }
.title { display: block; margin-top: 10rpx; font-size: 48rpx; font-weight: 900; }
.section-title { display: block; margin-top: 9rpx; font-size: 31rpx; font-weight: 900; }
.copy,.helper { display: block; margin-top: 13rpx; color: rgba(17,17,17,.56); font-size: 23rpx; line-height: 1.6; font-weight: 700; }
.section-heading { display: flex; align-items: center; justify-content: space-between; gap: 20rpx; }
.field { box-sizing: border-box; min-height: 92rpx; margin-top: 20rpx; padding: 0 28rpx; border: 2rpx solid rgba(17,17,17,.1); border-radius: 999rpx; background: #f6f6f4; font-size: 25rpx; font-weight: 800; }
.label { display: block; margin-top: 26rpx; font-size: 23rpx; font-weight: 900; }
.primary-button,.danger-button { min-height: 86rpx; margin: 22rpx 0 0; border-radius: 999rpx; font-size: 24rpx; font-weight: 900; }
.primary-button { background: #111; color: #fff; }
.danger-button { border: 2rpx solid rgba(123,41,41,.22); background: #fff; color: #7b2929; }
.small-button { min-height: 66rpx; margin: 0; padding: 0 22rpx; border: 2rpx solid rgba(17,17,17,.1); border-radius: 999rpx; background: #fff; color: #111; font-size: 21rpx; font-weight: 900; }
.readonly { display: block; margin-top: 22rpx; padding: 24rpx; border-radius: 22rpx; background: #f5f5f3; color: rgba(17,17,17,.6); font-size: 23rpx; line-height: 1.55; font-weight: 800; }
.inline-error { display: block; margin-top: 20rpx; padding: 20rpx 24rpx; border-radius: 20rpx; background: #f6eeee; color: #7b2929; font-size: 22rpx; line-height: 1.5; font-weight: 800; }
