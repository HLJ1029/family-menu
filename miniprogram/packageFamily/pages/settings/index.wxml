<page-state status="{{status}}" error-text="{{errorText}}" bind:retry="retry">
  <view class="settings-page" wx:if="{{household}}">
    <view class="hero-card">
      <text class="eyebrow">家庭设置</text>
      <text class="title">{{household.name}}</text>
      <text class="copy">{{canManage ? '名称、成员和硬性忌口由你统一维护。' : '你可以查看家庭信息，但只有家庭创建者能修改。'}}</text>
    </view>

    <view wx:if="{{canManage}}" class="section-card">
      <text class="eyebrow">基本信息</text>
      <text class="section-title">家庭名称</text>
      <input class="field" value="{{name}}" maxlength="32" placeholder="给这个家起个名字" bindinput="updateName" />
      <button class="primary-button" bindtap="saveName" loading="{{pendingAction === 'rename'}}" disabled="{{!!pendingAction}}">保存家庭名称</button>
    </view>

    <view class="section-card">
      <view class="section-heading">
        <view>
          <text class="eyebrow">成员管理</text>
          <text class="section-title">{{members.length}} 位正式成员</text>
        </view>
        <button wx:if="{{canManage}}" class="small-button" bindtap="openInvite" disabled="{{!!pendingAction}}">邀请家人</button>
      </view>
      <member-row
        wx:for="{{members}}"
        wx:key="id"
        member="{{item}}"
        current-member-id="{{currentMemberId}}"
        can-manage="{{canManage}}"
        pending-action="{{pendingAction}}"
        bind:transfer="transferOwnership"
        bind:remove="removeMember"
      />
      <text wx:if="{{canManage && members.length > 1}}" class="helper">转让主厨会把家庭设置和菜单管理权交给对方；移除成员前会再次确认。</text>
    </view>

    <view class="section-card">
      <text class="eyebrow">家庭偏好</text>
      <text class="section-title">硬性忌口</text>
      <text class="copy">推荐会优先避开这些食材。喜欢什么不用填，Humi 会从日常选择里慢慢学。</text>
      <block wx:if="{{canManage}}">
        <text class="label">家里不吃什么</text>
        <input class="field" value="{{dislikesText}}" maxlength="240" placeholder="例如：香菜、芹菜" bindinput="updateDislikes" />
        <text class="label">过敏或必须避开</text>
        <input class="field" value="{{allergiesText}}" maxlength="240" placeholder="例如：花生、海鲜" bindinput="updateAllergies" />
        <button class="primary-button" bindtap="savePreferences" loading="{{pendingAction === 'preferences'}}" disabled="{{!!pendingAction}}">保存家庭偏好</button>
      </block>
      <text wx:else class="readonly">家庭创建者统一维护：{{dislikesText || allergiesText ? dislikesText + (dislikesText && allergiesText ? '；' : '') + allergiesText : '目前没有硬性忌口'}}</text>
    </view>

    <view class="section-card">
      <text class="eyebrow">离开家庭</text>
      <text class="section-title">{{household.role === 'owner' ? '家庭创建者规则' : '离开这个家'}}</text>
      <text wx:if="{{ownerMustTransferBeforeLeaving}}" class="copy">这个家还有其他成员，请先转让主厨后再退出。</text>
      <text wx:else class="copy">{{household.role === 'owner' ? '你是最后一位成员，离开会解散这个家。' : '离开后不再同步这个家的菜单、清单和协作记录。'}}</text>
      <button class="danger-button" bindtap="leaveHousehold" loading="{{pendingAction === 'leave'}}" disabled="{{ownerMustTransferBeforeLeaving || !!pendingAction}}">{{household.role === 'owner' ? '解散这个家' : '离开这个家'}}</button>
    </view>

    <text wx:if="{{errorText}}" class="inline-error">{{errorText}}</text>
  </view>
</page-state>
