<view class="identity-shell">
  <view class="brand-mark">Humi</view>
  <view class="identity-card">
    <view class="eyebrow">你的 Humi 身份</view>
    <view class="title">以后家人会这样看到你。</view>
    <button class="wechat-profile-button" bindtap="useWechatProfile" disabled="{{pending}}">使用微信头像和昵称</button>
    <button class="avatar-button" open-type="chooseAvatar" bindchooseavatar="chooseAvatar" disabled="{{pending}}">
      <image wx:if="{{localAvatarUrl}}" class="avatar-image" src="{{localAvatarUrl}}" mode="aspectFill" />
      <view wx:else class="avatar-placeholder">选择一个头像</view>
    </button>
    <input class="nickname-input" type="nickname" value="{{displayName}}" placeholder="输入你的昵称" maxlength="32" bindinput="updateNickname" />
    <avatar-picker selected-avatar-key="{{selectedAvatarKey}}" bind:select="selectApprovedAvatar" />
    <button class="primary-button" bindtap="submit" loading="{{pending}}" disabled="{{!canSubmit || pending}}">保存并进入 Humi</button>
    <view wx:if="{{error}}" class="error-text">{{error}}</view>
  </view>
</view>
