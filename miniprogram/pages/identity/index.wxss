page {
  min-height: 100vh;
  background: #ffffff;
  color: #111111;
}

.identity-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 72rpx 44rpx;
  background: #ffffff;
  color: #111111;
}

.brand-mark {
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: 0.04em;
}

.identity-card {
  padding: 72rpx 0;
}

.eyebrow {
  margin-bottom: 20rpx;
  color: rgba(17, 17, 17, 0.38);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.28em;
}

.title {
  max-width: 560rpx;
  font-size: 62rpx;
  line-height: 1.03;
  font-weight: 900;
  letter-spacing: -0.04em;
}

.avatar-button {
  width: 176rpx;
  height: 176rpx;
  margin: 48rpx 0 28rpx;
  padding: 0;
  overflow: hidden;
  border-radius: 999rpx;
  background: #f2f0ea;
}

.avatar-image {
  width: 100%;
  height: 100%;
}

.avatar-placeholder {
  display: grid;
  place-items: center;
  width: 100%;
  height: 100%;
  padding: 18rpx;
  box-sizing: border-box;
  color: rgba(17, 17, 17, 0.48);
  font-size: 22rpx;
  font-weight: 800;
}

.nickname-input {
  min-height: 96rpx;
  padding: 0 32rpx;
  border-radius: 28rpx;
  background: #f6f5f1;
  font-size: 30rpx;
  font-weight: 800;
}

.primary-button {
  margin-top: 40rpx;
  min-height: 104rpx;
  border-radius: 999rpx;
  background: #111111;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.primary-button[disabled] {
  opacity: 0.48;
}

.error-text {
  margin-top: 24rpx;
  color: #8a2f24;
  font-size: 24rpx;
  font-weight: 700;
}
