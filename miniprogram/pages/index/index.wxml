<view wx:if="{{phoneBindVisible}}" class="login-shell">
  <view class="brand-mark">Humi</view>
  <view class="login-card">
    <view class="eyebrow">手机号绑定</view>
    <view class="title">让账号更容易找回。</view>
    <view class="body">
      手机号只用于账号绑定、登录验证和找回，不会用于菜单推荐或营销。
    </view>
    <button
      class="primary-button"
      open-type="getPhoneNumber"
      bindgetphonenumber="bindWechatPhone"
      loading="{{phoneBindPending}}"
      disabled="{{phoneBindPending}}"
    >
      授权绑定手机号
    </button>
    <button class="ghost-button" bindtap="cancelPhoneBind" disabled="{{phoneBindPending}}">
      暂不绑定
    </button>
    <view wx:if="{{phoneBindError}}" class="error-text">{{phoneBindError}}</view>
  </view>
</view>

<web-view wx:elif="{{url}}" src="{{url}}" bindmessage="handleMessage" binderror="handleError" bindload="handleLoad" />

<view wx:else class="login-shell">
  <view class="brand-mark">Humi</view>
  <view class="login-card">
    <view class="eyebrow">微信登录</view>
    <view class="title">正在连接你的 Humi 账号</view>
    <view class="body">
      登录后，今晚菜单、购物清单和家中库存会跟着微信账号保存。
    </view>
    <view wx:if="{{loginPending}}" class="loading-dot"></view>
    <button wx:else class="primary-button" bindtap="loginWithWechat">重新登录</button>
    <view wx:if="{{loginError}}" class="error-text">{{loginError}}</view>
  </view>
</view>
