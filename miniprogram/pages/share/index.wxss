page {
  min-height: 100vh;
  background: #f5f5f5;
  color: #111111;
}

.share-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 44rpx 36rpx 48rpx;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: rgba(17, 17, 17, 0.42);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.28em;
}

.brand-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #111111;
}

.share-card {
  margin-top: 38rpx;
  padding: 40rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.1);
  border-radius: 28rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 80rpx rgba(17, 17, 17, 0.08);
}

.eyebrow {
  color: rgba(17, 17, 17, 0.44);
  font-size: 24rpx;
  font-weight: 900;
}

.title {
  margin-top: 18rpx;
  font-size: 50rpx;
  line-height: 1.14;
  font-weight: 900;
}

.body {
  margin-top: 24rpx;
  color: rgba(17, 17, 17, 0.58);
  font-size: 28rpx;
  line-height: 1.62;
  font-weight: 700;
}

.detail-list {
  margin-top: 32rpx;
  border-top: 2rpx solid rgba(17, 17, 17, 0.08);
}

.detail-row {
  padding: 24rpx 0;
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 28rpx;
  border-bottom: 2rpx solid rgba(17, 17, 17, 0.08);
}

.detail-label {
  flex-shrink: 0;
  color: rgba(17, 17, 17, 0.42);
  font-size: 23rpx;
  font-weight: 800;
}

.detail-value {
  max-width: 390rpx;
  color: #111111;
  font-size: 24rpx;
  line-height: 1.45;
  text-align: right;
  font-weight: 800;
}

.meta-row {
  margin-top: 28rpx;
  display: flex;
  justify-content: space-between;
  gap: 24rpx;
  color: rgba(17, 17, 17, 0.44);
  font-size: 24rpx;
  font-weight: 900;
}

.actions {
  padding-top: 36rpx;
}

.share-helper {
  margin-bottom: 18rpx;
  padding: 0 20rpx;
  color: rgba(17, 17, 17, 0.5);
  font-size: 24rpx;
  line-height: 1.5;
  text-align: center;
  font-weight: 700;
}

.primary-button,
.ghost-button {
  min-height: 104rpx;
  border-radius: 999rpx;
  font-size: 30rpx;
  font-weight: 900;
}

.primary-button {
  background: #111111;
  color: #ffffff;
}

.ghost-button {
  margin-top: 20rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.12);
  background: #ffffff;
  color: rgba(17, 17, 17, 0.62);
}
