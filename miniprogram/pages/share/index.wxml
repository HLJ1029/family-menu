<view class="share-shell">
  <view class="share-content">
    <view class="brand-row">
      <view class="brand-dot"></view>
      <text>HUMI</text>
    </view>

    <view class="share-card">
      <view class="eyebrow">{{eyebrow}}</view>
      <view class="title">{{title}}</view>
      <view class="body">{{body}}</view>
      <view class="detail-list">
        <view class="detail-row" wx:for="{{detailRows}}" wx:key="label">
          <text class="detail-label">{{item.label}}</text>
          <text class="detail-value">{{item.value}}</text>
        </view>
      </view>
      <view class="meta-row">
        <text>{{householdName}}</text>
        <text>{{meta}}</text>
      </view>
    </view>
  </view>

  <view class="actions">
    <view class="share-helper">{{helper}}</view>
    <button class="hero-share-button primary-button" open-type="share">{{actionLabel}}</button>
    <button class="ghost-button" bindtap="goBack">返回 Humi</button>
  </view>
</view>
