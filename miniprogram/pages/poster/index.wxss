page {
  min-height: 100vh;
  background: #f5f5f5;
  color: #111111;
}

.poster-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 42rpx 34rpx calc(48rpx + env(safe-area-inset-bottom));
}

.brand-row {
  display: flex;
  align-items: center;
  gap: 14rpx;
  color: rgba(17, 17, 17, 0.42);
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0.28em;
}

.brand-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 999rpx;
  background: #111111;
}

.poster-heading {
  margin-top: 34rpx;
}

.eyebrow {
  color: rgba(17, 17, 17, 0.44);
  font-size: 24rpx;
  font-weight: 900;
}

.title {
  margin-top: 14rpx;
  font-size: 48rpx;
  line-height: 1.16;
  font-weight: 900;
}

.poster-frame {
  margin-top: 34rpx;
  overflow: hidden;
  border: 2rpx solid rgba(17, 17, 17, 0.1);
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 24rpx 72rpx rgba(17, 17, 17, 0.1);
}

.poster-image {
  display: block;
  width: 100%;
  background: #ffffff;
}

.poster-missing {
  margin-top: 34rpx;
  padding: 72rpx 36rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.1);
  border-radius: 24rpx;
  background: #ffffff;
  text-align: center;
}

.missing-title {
  font-size: 32rpx;
  font-weight: 900;
}

.missing-body,
.poster-status {
  color: rgba(17, 17, 17, 0.56);
  font-size: 25rpx;
  line-height: 1.55;
  font-weight: 700;
}

.missing-body {
  margin-top: 14rpx;
}

.poster-status {
  min-height: 78rpx;
  padding: 28rpx 14rpx 0;
  text-align: center;
}

.actions {
  margin-top: 26rpx;
}

.primary-button,
.secondary-button,
.ghost-button {
  min-height: 100rpx;
  border-radius: 999rpx;
  font-size: 29rpx;
  font-weight: 900;
}

.primary-button {
  background: #111111;
  color: #ffffff;
}

.secondary-button,
.ghost-button {
  margin-top: 18rpx;
  border: 2rpx solid rgba(17, 17, 17, 0.12);
  background: #ffffff;
  color: #111111;
}

.ghost-button {
  color: rgba(17, 17, 17, 0.58);
}

button[disabled] {
  opacity: 0.46;
}
