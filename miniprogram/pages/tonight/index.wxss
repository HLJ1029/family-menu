page {
  min-height: 100vh;
  background: #f4f2ed;
}

.tonight-shell {
  min-height: 100vh;
  box-sizing: border-box;
  padding: 44rpx 32rpx 180rpx;
}

.tonight-header {
  padding: 16rpx 4rpx 36rpx;
}

.eyebrow,
.title,
.subtitle,
.offline-pill,
.inline-error,
.pending-note {
  display: block;
}

.eyebrow {
  color: rgba(17, 17, 17, 0.38);
  font-size: 20rpx;
  font-weight: 900;
  letter-spacing: 0.23em;
}

.title {
  max-width: 650rpx;
  margin-top: 18rpx;
  font-size: 60rpx;
  font-weight: 900;
  letter-spacing: -0.045em;
  line-height: 1.04;
}

.subtitle {
  max-width: 620rpx;
  margin-top: 18rpx;
  color: rgba(17, 17, 17, 0.56);
  font-size: 25rpx;
  font-weight: 650;
  line-height: 1.55;
}

.offline-pill {
  width: fit-content;
  margin-top: 20rpx;
  padding: 9rpx 15rpx;
  border-radius: 999rpx;
  background: #e7e1d3;
  color: #66583d;
  font-size: 20rpx;
  font-weight: 800;
}

.inline-error {
  margin-top: 22rpx;
  padding: 20rpx 24rpx;
  border-radius: 22rpx;
  background: #f2dfd9;
  color: #7a2c20;
  font-size: 23rpx;
  font-weight: 750;
  line-height: 1.45;
}

.pending-note {
  margin-top: 20rpx;
  color: rgba(17, 17, 17, 0.48);
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}
