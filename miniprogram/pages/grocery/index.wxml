<page-state status="{{status}}" error-text="{{errorText}}" bind:retry="retry">
  <view class="native-tab">
    <text class="eyebrow">{{householdName}}</text>
    <text class="native-tab-title">这周要买什么</text>
    <text class="native-tab-copy">从晚餐计划自动整理；家人都能勾选、领取和分享。</text>
    <view wx:if="{{status === 'cached'}}" class="notice">正在显示离线缓存；勾选会在联网后同步。</view>
    <view wx:if="{{conflictVisible}}" class="notice conflict">家人刚更新了清单，下面已是最新状态。</view>
    <view wx:if="{{errorText && status !== 'error'}}" class="notice">{{errorText}}</view>
    <view wx:if="{{!items.length}}" class="empty">先在“计划”里安排晚餐，清单会自动出现。</view>
    <view wx:else class="list">
      <grocery-item
        wx:for="{{items}}"
        wx:key="id"
        item="{{item}}"
        current-member-id="{{currentMemberId}}"
        busy="{{pendingAction !== ''}}"
        bind:check="checkItem"
        bind:claim="claimItem"
      />
    </view>
    <button
      wx:if="{{items.length && canCollaborate}}"
      class="share-button"
      open-type="share"
      data-share-type="grocery"
      disabled="{{!preparedShares.grocery || sharePreparing.grocery}}"
      loading="{{sharePreparing.grocery}}"
    >分享只读清单</button>
    <text
      wx:if="{{shareErrors.grocery}}"
      class="share-retry"
      data-share-type="grocery"
      bindtap="retryNativeShare"
    >分享内容没准备好，点这里重试</text>
  </view>
</page-state>
