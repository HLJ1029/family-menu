.native-tab { padding: 40rpx 28rpx 180rpx; }
.eyebrow { display: block; color: #777; font-size: 24rpx; font-weight: 700; }
.native-tab-title { display: block; margin-top: 8rpx; color: #111; font-size: 48rpx; font-weight: 800; }
.native-tab-copy { display: block; margin: 16rpx 0 28rpx; color: #666; font-size: 27rpx; line-height: 1.6; }
.notice, .empty { margin-bottom: 24rpx; padding: 22rpx 24rpx; border-radius: 20rpx; background: #f2f2f2; color: #555; font-size: 24rpx; }
.conflict { background: #fff0dc; color: #75450a; }
.list { padding: 0 26rpx; border: 1rpx solid #e8e8e8; border-radius: 28rpx; background: #fff; }
.share-button { margin-top: 30rpx; border-radius: 999rpx; background: #111; color: #fff; font-size: 28rpx; font-weight: 700; }
.share-button::after { border: 0; }
.share-button[disabled] { background: #d4d1cc; color: #777; }
.share-retry { display: block; margin: 18rpx auto 0; color: #7b2929; font-size: 25rpx; text-align: center; text-decoration: underline; }
