<page-state status="{{status}}" error-text="{{errorText}}" bind:retry="retry">
  <view class="share-landing">
    <text class="eyebrow">{{grocery.householdName || '家人'}} · 清单</text>
    <text class="title">{{grocery.title || '这周买菜清单'}}</text>
    <text class="copy">{{grocery.initiatorName || '家人'}}发来一份只读清单</text>
    <view class="card">
      <view wx:for="{{grocery.items}}" wx:key="id" class="row {{item.checked ? 'checked' : ''}}">
        <text class="check">{{item.checked ? '✓' : '○'}}</text>
        <view class="item-copy">
          <text class="item-name">{{item.name}}</text>
          <text wx:if="{{item.amount || item.category}}" class="meta">{{item.amount}} {{item.category}}</text>
        </view>
      </view>
    </view>
    <text class="readonly">这是只读清单。查看不会领取、勾选或改动家人的清单。</text>
  </view>
</page-state>
