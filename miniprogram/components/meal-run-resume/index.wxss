.run-card {
  padding: 34rpx;
  border-radius: 38rpx;
  background: #111111;
  color: #ffffff;
}

.run-kicker,
.run-title,
.run-companion,
.completed-note {
  display: block;
}

.run-kicker {
  color: rgba(255, 255, 255, 0.58);
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0.14em;
}

.run-title {
  margin-top: 18rpx;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.05;
}

.run-companion {
  margin-top: 12rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 25rpx;
  font-weight: 750;
}

.run-facts {
  display: flex;
  gap: 12rpx;
  margin-top: 28rpx;
}

.run-facts text {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.12);
  font-size: 20rpx;
  font-weight: 800;
}

.run-primary {
  min-height: 98rpx;
  margin-top: 36rpx;
  border-radius: 999rpx;
  background: #ffffff;
  color: #111111;
  font-size: 29rpx;
  font-weight: 900;
}

.replace-action {
  min-height: 72rpx;
  margin-top: 12rpx;
  background: transparent;
  color: rgba(255, 255, 255, 0.65);
  font-size: 23rpx;
  font-weight: 800;
}

.completed-note {
  margin-top: 32rpx;
  color: rgba(255, 255, 255, 0.72);
  font-size: 24rpx;
  line-height: 1.55;
}
