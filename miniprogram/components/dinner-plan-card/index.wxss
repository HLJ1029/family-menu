.plan-card {
  padding: 28rpx;
  border-radius: 38rpx;
  background: #ffffff;
  box-shadow: 0 18rpx 60rpx rgba(17, 17, 17, 0.07);
}

.plan-topline,
.recipe,
.plan-facts,
.missing,
.plan-actions {
  display: flex;
  align-items: center;
}

.plan-topline,
.missing {
  justify-content: space-between;
}

.plan-kicker {
  color: rgba(17, 17, 17, 0.5);
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.plan-time {
  font-size: 27rpx;
  font-weight: 900;
}

.recipe-list {
  display: grid;
  gap: 18rpx;
  margin-top: 24rpx;
}

.recipe-image {
  flex: none;
  width: 132rpx;
  height: 112rpx;
  border-radius: 24rpx;
  background: #eceae4;
}

.recipe-copy {
  min-width: 0;
  margin-left: 22rpx;
}

.recipe-title,
.recipe-detail,
.missing-label,
.missing-value,
.permission-copy {
  display: block;
}

.recipe-title {
  font-size: 34rpx;
  font-weight: 900;
}

.recipe-detail {
  margin-top: 8rpx;
  color: rgba(17, 17, 17, 0.5);
  font-size: 22rpx;
  font-weight: 700;
}

.plan-facts {
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 24rpx;
}

.plan-facts text {
  padding: 10rpx 14rpx;
  border-radius: 999rpx;
  background: #f3f1eb;
  font-size: 20rpx;
  font-weight: 800;
}

.missing {
  align-items: flex-start;
  margin-top: 24rpx;
  padding-top: 22rpx;
  border-top: 2rpx solid rgba(17, 17, 17, 0.08);
}

.missing-label {
  color: rgba(17, 17, 17, 0.45);
  font-size: 22rpx;
  font-weight: 800;
}

.missing-value {
  max-width: 470rpx;
  margin-left: 24rpx;
  font-size: 23rpx;
  font-weight: 800;
  text-align: right;
}

.plan-actions {
  gap: 14rpx;
  margin-top: 28rpx;
}

.primary-action,
.secondary-action {
  min-height: 94rpx;
  margin: 0;
  border-radius: 999rpx;
  font-size: 27rpx;
  font-weight: 900;
}

.primary-action {
  flex: 1.45;
  background: #111111;
  color: #ffffff;
}

.secondary-action {
  flex: 1;
  border: 2rpx solid rgba(17, 17, 17, 0.14);
  background: #ffffff;
  color: #111111;
}

.primary-action[disabled],
.secondary-action[disabled] {
  opacity: 0.48;
}

.permission-copy {
  margin-top: 18rpx;
  color: #7b5b20;
  font-size: 21rpx;
  font-weight: 700;
  text-align: center;
}
