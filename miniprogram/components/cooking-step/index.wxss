.step-card {
  padding: 30rpx;
  border: 1rpx solid rgba(17, 17, 17, 0.08);
  border-radius: 32rpx;
  background: #ffffff;
  box-shadow: 0 20rpx 48rpx rgba(17, 17, 17, 0.06);
}

.step-topline {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.recipe-name,
.attention-pill,
.step-text,
.rescue-tip,
.next-label,
.next-text,
.last-step {
  display: block;
}

.recipe-name {
  font-size: 23rpx;
  font-weight: 900;
}

.attention-pill {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  border-radius: 999rpx;
  background: #ebe6db;
  color: #5d513a;
  font-size: 19rpx;
  font-weight: 800;
}

.step-text {
  margin-top: 26rpx;
  font-size: 35rpx;
  font-weight: 900;
  letter-spacing: -0.02em;
  line-height: 1.42;
}

.rescue-tip {
  margin-top: 20rpx;
  padding: 18rpx 20rpx;
  border-radius: 18rpx;
  background: #f2eee5;
  color: #65593f;
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.45;
}

.next-preview {
  margin-top: 28rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid rgba(17, 17, 17, 0.08);
}

.next-label {
  color: rgba(17, 17, 17, 0.4);
  font-size: 19rpx;
  font-weight: 900;
  letter-spacing: 0.12em;
}

.next-text {
  margin-top: 8rpx;
  color: rgba(17, 17, 17, 0.62);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 1.42;
}

.advance-button {
  height: 88rpx;
  margin-top: 26rpx;
  border-radius: 44rpx;
  background: #111111;
  color: #ffffff;
  font-size: 25rpx;
  font-weight: 850;
}

.last-step {
  margin-top: 26rpx;
  color: rgba(17, 17, 17, 0.5);
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}
