<view class="step-card">
  <view class="step-topline">
    <text class="recipe-name">{{step.recipeName}}</text>
    <text class="attention-pill">{{step.attention === 'passive' ? '等待步骤' : '需要动手'}}</text>
  </view>
  <text class="step-text">{{step.text}}</text>
  <text wx:if="{{step.rescueTip}}" class="rescue-tip">没按计划？{{step.rescueTip}}</text>
  <view wx:if="{{nextStep}}" class="next-preview">
    <text class="next-label">接下来</text>
    <text class="next-text">{{nextStep.recipeName}} · {{nextStep.text}}</text>
  </view>
  <button
    wx:if="{{nextStep}}"
    class="advance-button"
    bindtap="advance"
    loading="{{pending}}"
    disabled="{{pending}}"
  >这一步完成了</button>
  <view wx:elif="{{hasRemainingSteps}}" class="last-step">还在等待计时，结束后会自动出现下一步。</view>
  <view wx:else class="last-step">最后一步完成后，就可以点“上桌了”。</view>
</view>
