.image-frame {
  position: relative;
  width: 100%;
  height: 100%;
  overflow: hidden;
  background: #eceae6;
}

.humi-dish-placeholder,
.remote-image {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
}

.humi-dish-placeholder {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #77736d;
  background: #eceae6;
}

.placeholder-plate {
  width: 108rpx;
  height: 108rpx;
  border: 12rpx solid #d6d2cb;
  border-radius: 999rpx;
  box-shadow: inset 0 0 0 4rpx #e3e0da;
}

.placeholder-copy {
  margin-top: 18rpx;
  font-size: 22rpx;
}

.remote-image {
  opacity: 0;
  transition: opacity 160ms ease;
}

.remote-image.is-loaded {
  opacity: 1;
}

.retry-button {
  position: absolute;
  right: 16rpx;
  bottom: 16rpx;
  min-width: 92rpx;
  height: 52rpx;
  padding: 0 18rpx;
  border-radius: 999rpx;
  color: #ffffff;
  background: rgba(17, 17, 17, 0.82);
  font-size: 22rpx;
  line-height: 52rpx;
}

.retry-button::after {
  border: 0;
}
