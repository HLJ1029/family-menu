.member-row { display: flex; align-items: center; gap: 20rpx; padding: 22rpx 0; border-bottom: 2rpx solid rgba(17,17,17,.07); }
.avatar { width: 76rpx; height: 76rpx; flex: 0 0 auto; border-radius: 26rpx; background: #f2f2f0; }
.fallback { display: grid; place-items: center; color: #111; font-size: 26rpx; font-weight: 900; }
.member-copy { min-width: 0; flex: 1; }
.member-title { display: flex; align-items: center; gap: 12rpx; color: #111; font-size: 27rpx; font-weight: 900; }
.you { padding: 4rpx 12rpx; border-radius: 999rpx; background: #f1f1ef; color: rgba(17,17,17,.55); font-size: 18rpx; }
.member-meta { display: block; margin-top: 6rpx; color: rgba(17,17,17,.5); font-size: 21rpx; font-weight: 700; }
.member-actions { display: flex; gap: 8rpx; }
.mini-button { min-height: 58rpx; margin: 0; padding: 0 16rpx; border: 2rpx solid rgba(17,17,17,.1); border-radius: 999rpx; background: #fff; color: #111; font-size: 19rpx; font-weight: 900; }
.mini-button.danger { color: #7b2929; }
