.avatar-picker {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  gap: 16rpx;
  margin-top: 28rpx;
}

.avatar-option {
  width: 100%;
  aspect-ratio: 1;
  padding: 0;
  overflow: hidden;
  border: 4rpx solid transparent;
  border-radius: 999rpx;
  background: #f2f0ea;
}

.avatar-option.selected {
  border-color: #111111;
}

.avatar-option image {
  width: 100%;
  height: 100%;
}
